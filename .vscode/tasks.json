{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync: upstream + origin",
            "type": "shell",
            "command": "git fetch upstream && git fetch origin && git rebase upstream/main && git push --force-with-lease origin main",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "close": true
            },
            "problemMatcher": []
        }
    ]
}
